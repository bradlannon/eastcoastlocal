DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
CRON_SECRET=your-secret-token
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
EVENTBRITE_TOKEN=your-eventbrite-token
BANDSINTOWN_APP_ID=your-bandsintown-app-id
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=your-sha256-hex-hash
JWT_SECRET=your-random-secret-at-least-32-chars

TICKETMASTER_API_KEY=your-ticketmaster-api-key

# Gmail Newsletter Parser (OAuth2)
# Create at https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0
# Enable Gmail API, set redirect URI to https://developers.google.com/oauthplayground
# Use OAuth Playground to get refresh token with scope: https://www.googleapis.com/auth/gmail.modify
GMAIL_CLIENT_ID=your-google-oauth-client-id
GMAIL_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
GMAIL_LABEL=ECL/events